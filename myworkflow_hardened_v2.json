    {
      "parameters": {
        "jsCode": "let text = String($input.first()?.json?.text || '');\nconst start = text.indexOf('{');\nconst end = text.lastIndexOf('}') + 1;\nif (start === -1) return [{ json: { text: \"\" } }];\ntry {\n  const data = JSON.parse(text.slice(start, end));\n  return (data.queries || []).map(q => ({ json: { text: q } }));\n} catch (e) { return []; }"
      },
