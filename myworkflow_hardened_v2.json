        "jsCode": "const item = $input.first();\nconst body = item?.json?.body || {};\n\nconst prompt = String(body.prompt || body.instructions || body.chatInput || '').trim();\nif (!prompt) {\n  throw new Error('Instruction or prompt is required for question generation');\n}\n\nreturn [\n  {\n    json: {\n      ...item.json,\n      body: {\n        ...body,\n        prompt\n      }\n    }\n  }\n];"
