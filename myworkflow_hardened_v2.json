      "id": "rerank-ollama",
      "name": "Ollama Chat Model1"
    },
    {
      "parameters": {
        "jsCode": "let text = String($input.first()?.json?.text || '');\nconst start = text.indexOf('{');\nconst end = text.lastIndexOf('}') + 1;\nif (start === -1) return [{ json: { text: \"No context\" } }];\n\ntry {\n  const data = JSON.parse(text.slice(start, end));\n  const chunks = data.chunks || data.top_chunks || [];\n  return chunks.map(c => ({ json: { text: (typeof c === 'string' ? c : (c.text || JSON.stringify(c))) } }));\n} catch (e) {\n  return [{ json: { text: text.slice(0, 1000) } }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        160
      ],
      "id": "rerank-parse-node",
      "name": "Safe Rerank Parse"
