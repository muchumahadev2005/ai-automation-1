# Frontend Environment Configuration

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# N8N Webhook Configuration
# The base URL for n8n webhook endpoints
# Point to your n8n instance webhook URLs
VITE_N8N_WEBHOOK_BASE=http://localhost:5678/webhook

# Example webhook URLs:
# - Syllabus upload: http://localhost:5678/webhook/syllabus-upload
# - Teacher question: http://localhost:5678/webhook/teacher-question
